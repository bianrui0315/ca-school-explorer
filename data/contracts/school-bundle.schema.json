{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/bianrui0315/ca-school-explorer/data/contracts/school-bundle.schema.json",
  "title": "California School Explorer school bundle",
  "description": "Browser-safe derived metrics for one education entity. Raw source records are not part of this contract.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "entity", "source_snapshots", "observations"],
  "properties": {
    "schema_version": { "const": 1 },
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cds_code", "name", "district_name", "status", "grade_span"],
      "properties": {
        "cds_code": { "type": "string", "pattern": "^[0-9]{14}$" },
        "name": { "type": "string", "minLength": 1 },
        "district_name": { "type": "string", "minLength": 1 },
        "status": { "enum": ["active", "pending", "closed", "merged"] },
        "grade_span": { "type": "string", "minLength": 1 }
      }
    },
    "source_snapshots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_id", "retrieved_at", "sha256"],
        "properties": {
          "source_id": { "type": "string", "minLength": 1 },
          "retrieved_at": { "type": "string", "format": "date-time" },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "observations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "school_year",
          "metric_id",
          "subgroup_id",
          "value",
          "numerator",
          "denominator",
          "reliability"
        ],
        "properties": {
          "school_year": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
          "metric_id": { "type": "string", "minLength": 1 },
          "subgroup_id": { "type": "string", "minLength": 1 },
          "value": { "type": ["number", "null"] },
          "numerator": { "type": ["number", "null"], "minimum": 0 },
          "denominator": { "type": ["integer", "null"], "minimum": 0 },
          "reliability": {
            "enum": ["reliable", "small-sample", "suppressed", "not-available", "method-break"]
          }
        }
      }
    }
  }
}
