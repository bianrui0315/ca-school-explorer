{
  "name": "ca-school-explorer-workspace",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "data:publish": "./.venv/bin/python -m ca_school_explorer publish-public-data --release 0.1.1",
    "web:dev": "npm --workspace @ca-school-explorer/web run dev",
    "web:build": "npm --workspace @ca-school-explorer/web run build",
    "web:lint": "npm --workspace @ca-school-explorer/web run lint",
    "web:test": "npm --workspace @ca-school-explorer/web run test",
    "worker:dev": "npm run web:build && wrangler dev",
    "worker:dry-run": "npm run web:build && wrangler deploy --dry-run",
    "worker:deploy": "npm run web:build && wrangler deploy",
    "release:check": "npm run web:lint && npm run web:test && npm run worker:dry-run",
    "release:deploy": "npm run worker:deploy"
  },
  "devDependencies": {
    "wrangler": "^4.110.0"
  }
}
